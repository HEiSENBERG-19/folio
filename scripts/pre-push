#!/usr/bin/env bash
# Folio pre-push hook
# Runs tests before allowing a push.
# Install: cp scripts/pre-push .git/hooks/pre-push

set -e

echo "🧪 Running pre-push checks..."

# --- Backend tests (pytest) ---
if [ -d "backend/.venv" ]; then
    echo "  ▸ Backend: pytest"
    cd backend
    source .venv/bin/activate 2>/dev/null || true
    python -m pytest --tb=short -q
    cd ..
else
    echo "  ▸ Backend: .venv not found, skipping pytest"
fi

# --- Frontend type check + unit tests + build ---
if [ -d "frontend/node_modules" ]; then
    echo "  ▸ Frontend: type check (tsc --noEmit)"
    cd frontend && npx tsc --noEmit
    echo "  ▸ Frontend: vitest"
    npx vitest run --reporter=dot
    echo "  ▸ Frontend: build"
    npm run build --silent
    cd ..
else
    echo "  ▸ Frontend: node_modules missing, skipping build check"
fi

echo "✅ Pre-push checks passed."
